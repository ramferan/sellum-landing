---
const year = 2026;
---
<!DOCTYPE html>
<html class="light" lang="es">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Nebula — Trading Intelligence</title>
<meta name="description" content="Señales de trading semanales impulsadas por Deep Learning LSTM y análisis macro."/>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com"></script>
<script>tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-dim":"#dadada","surface-bright":"#f9f9f9","background":"#f9f9f9","on-background":"#1a1c1c","surface-variant":"#e2e2e2","primary":"#000000","secondary":"#5d5f5f","on-primary":"#ffffff","on-secondary":"#ffffff","outline":"#7e7576","surface":"#f9f9f9","on-surface":"#1a1c1c"},"borderRadius":{"DEFAULT":"0px","lg":"0px","xl":"0px","full":"9999px"},"spacing":{"margin-desktop":"64px","stack-md":"40px","gutter":"24px","unit":"8px","margin-mobile":"24px","container-max":"1280px"},"fontFamily":{"headline-lg":["Playfair Display"],"body-md":["Hanken Grotesk"],"body-lg":["Hanken Grotesk"],"label-caps":["Hanken Grotesk"],"display-lg":["Playfair Display"],"headline-md":["Playfair Display"]},"fontSize":{"headline-lg":["40px",{"lineHeight":"48px","fontWeight":"600"}],"body-lg":["18px",{"lineHeight":"28px","fontWeight":"400"}],"body-md":["16px",{"lineHeight":"24px","fontWeight":"400"}],"label-caps":["12px",{"lineHeight":"16px","letterSpacing":"0.1em","fontWeight":"600"}],"display-lg":["72px",{"lineHeight":"80px","letterSpacing":"-0.02em","fontWeight":"700"}],"headline-md":["24px",{"lineHeight":"32px","fontWeight":"500"}]}}}}</script>
<style>body{background-color:#f9f9f9;color:#000;-webkit-font-smoothing:antialiased}.editorial-border{border:1px solid #E5E5E5}</style>
</head>
<body class="font-body-md">
<header class="border-b border-surface-variant bg-background sticky top-0 z-50">
<nav class="flex justify-between items-center px-margin-mobile md:px-margin-desktop py-unit max-w-container-max mx-auto">
  <span class="font-display-lg text-headline-md font-bold text-primary">Nebula</span>
  <div class="flex items-center gap-4">
    <a href="mailto:info@sellumlabs.com" class="font-label-caps text-label-caps text-secondary hover:text-primary transition-colors">Contact</a>
  </div>
</nav>
</header>
<main>
<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-xl min-h-[70vh] flex flex-col justify-center">
  <div class="max-w-4xl">
    <span class="font-label-caps text-label-caps text-primary tracking-[0.2em] mb-4 block">TRADING INTELLIGENCE</span>
    <h1 class="font-display-lg text-display-lg md:text-[120px] md:leading-[110px] text-primary mb-stack-md">Nebula</h1>
    <p class="font-body-lg text-body-lg text-secondary max-w-2xl leading-relaxed mb-12">
      Señales de trading semanales impulsadas por modelos Deep Learning LSTM y análisis de régimen macro. Más información, menos ruido.
    </p>
    <div class="editorial-border bg-white p-6 max-w-md">
      <div class="grid grid-cols-2 gap-4 text-label-sm font-label-sm">
        <div class="text-secondary uppercase tracking-wider">Status</div><div class="text-right">En desarrollo</div>
        <div class="text-secondary uppercase tracking-wider">Próximo hito</div><div class="text-right">Q3 2026</div>
      </div>
    </div>
  </div>
</section>
</main>
<footer class="border-t border-surface-variant mt-stack-xl">
<div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-md text-center text-secondary font-body-md text-sm">
  &copy; {year} Nebula. Todos los derechos reservados.
</div>
</footer>
</body></html>
