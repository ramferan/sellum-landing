---
import BaseLayout from '../../layouts/BaseLayout.astro';
import t from '../../i18n/es.json';
const lang = 'es';
const k = t.kalosnap;
const appUrl = 'https://app.kalosnap.sellumlabs.com/login';
const heroBg = 'https://lh3.googleusercontent.com/aida-public/AB6AXuDvMnIRScXpBebiorLMdmsjSDVp0rIYDY6Tm_PfTDcFLDJEUt6o8FJEU6ARiIsj7rHND7gwDlHrxeSOVNcqtYmO48kp15BJ9bc7AqwfZ87k90WiV1ZUUECLi6mpBDiS8Lq27R7gNw-mhe_f2qresMYZ5ako_Rm538g83w4cIKQkFfMTvdKXlwzckF-M2CHE12tOYYj1lVYlaeiWwHF2-j70RX3ENfbIR266okAyx1jp1aP_hS_m9ei6uV8a2Ylh1u4SaWut5iikAw';
const featBg = 'https://lh3.googleusercontent.com/aida-public/AB6AXuAxle6_7eRDZNUQ_PeEfCKY0kF_qSfw8_ypM8-JITNplduggw6JdohZO5sUuU7pbVnb0woGwSMMXzqo0XyDK7sRho9UC0ra3ynWV871ssP_rsrNSICqvxd-KaX7opw7DCZvQuXOILxf2ELpPpngxY5TPnHtBX0ZiKR_dpkZ0BNCYyj8ioQMYIwZ3xTVmQtoGibTxRkRK4x8XEEzHnwaT4WYIQXUp_QnWNuGgB2RQScll3KUuggBZwOOO6uMikHmLc2um1iMc_xtkQ';
const logoUrl = 'https://lh3.googleusercontent.com/aida/AP1WRLtEvTrGA3q5xc8FeF_5e7QAy_Abg2TzcwGIq_eYTwp_sJ56NJNZ5B531cOCRlzTOjUQj3WR9en4_M25eR8gSo3pwV3w_wPHy3IBd9trtexYAgY6qE3Ym_9FD4QFz-NbcbD2t27gSKtkSjaDzsAHB59728k373mcSOxJfhrmtnjbdoMltKxYve0MA6ZfqIVdrSGzqqIlrDC1r2v6tI02kTaZWnq3feWyoy_A5JKPuuDkCVb39Dggt8AvdQ';
---
<BaseLayout lang={lang} t={t} title={k.title} description={k.description} variant="kalosnap" ctaUrl={appUrl}>
<section class="min-h-[80vh] flex flex-col justify-center px-margin-mobile md:px-margin-desktop py-16">
<div class="max-w-4xl"><span class="font-label-md text-label-md uppercase tracking-[0.2em] mb-4 block text-secondary">{k.hero_tag}</span>
<h1 class="font-display-lg text-[64px] md:text-[120px] leading-none mb-12 tracking-tighter">KaloSnap</h1>
<p class="font-body-lg text-body-lg text-secondary max-w-2xl mb-12 -mt-8">{k.hero_sub}</p>
<div class="flex flex-col md:flex-row gap-gutter">
<a href={appUrl} class="bg-[#0ea5a0] text-white px-12 py-4 font-label-md text-label-md uppercase tracking-widest hover:bg-[#0c8f8b] transition-all cursor-pointer inline-block">{k.cta}</a>
<button class="border hairline-border px-12 py-4 font-label-md text-label-md uppercase tracking-widest hover:bg-surface-container-low transition-all cursor-pointer">{k.view_science}</button>
</div></div>
<div class="mt-20 hairline-border w-full aspect-[21/9] relative overflow-hidden grayscale contrast-125">
<div class="w-full h-full bg-cover bg-center" style="background-image:url('{heroBg}')"></div>
<div class="absolute bottom-4 left-4 bg-background px-3 py-1 font-label-sm text-label-sm hairline-border">{k.system_init}</div></div>
</section>
<section class="grid grid-cols-1 md:grid-cols-2 hairline-t">
<div class="p-margin-mobile md:p-margin-desktop hairline-r flex flex-col justify-center">
<h2 class="font-headline-lg text-headline-lg mb-6">{k.section_title}</h2>
<p class="font-body-lg text-body-lg text-secondary max-w-md mb-8">{k.section_desc}</p>
<div class="hairline-border p-6 bg-surface-container-lowest">
<div class="flex items-center gap-4 mb-2"><span class="w-2 h-2 bg-primary"></span><span class="font-label-md text-label-md uppercase tracking-tight">ID Análisis Plato: 8829-K</span></div>
<div class="grid grid-cols-2 gap-4 mt-4 text-label-sm font-label-sm"><div class="text-secondary">CONFIANZA</div><div class="text-right">0.992</div><div class="text-secondary">LATENCIA_MS</div><div class="text-right">412ms</div></div></div></div>
<div class="relative bg-surface-container"><div class="w-full h-full min-h-[500px] bg-cover bg-center" style="background-image:url('{featBg}')"></div><div class="absolute inset-0 bg-primary/5"></div></div>
</section>
<section class="hairline-t grid grid-cols-1 md:grid-cols-3">
{[{icon:'photo_camera',title:k.module1_title,desc:k.module1_desc},{icon:'calculate',title:k.module2_title,desc:k.module2_desc},{icon:'query_stats',title:k.module3_title,desc:k.module3_desc}].map((m,i)=>
<div class="p-12 md:p-16 hairline-r flex flex-col gap-8 group hover:bg-surface-container-lowest transition-colors"><span class="material-symbols-outlined text-[40px]">{m.icon}</span><div><h3 class="font-headline-md text-headline-md mb-4">{m.title}</h3><p class="text-secondary">{m.desc}</p></div><div class="mt-auto pt-4 font-label-sm text-label-sm text-secondary uppercase tracking-widest border-t border-outline-variant w-fit">Módulo 0{i+1}</div></div>
)}
</section>
<section class="hairline-t px-margin-mobile md:px-margin-desktop py-24 bg-surface-container-lowest">
<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
<div class="max-w-xl"><h2 class="font-headline-lg text-headline-lg mb-4">{k.chart_title}</h2><p class="text-secondary font-body-lg">{k.chart_desc}</p></div>
<div class="text-right"><span class="font-display-lg text-[84px] leading-none">84%</span><span class="block font-label-md text-label-md text-secondary uppercase tracking-widest mt-2">{k.chart_progress}</span></div></div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-0 hairline-border">
{[{label:'Carbohidratos',val:'42%',g:'42'},{label:'Proteínas',val:'78%',g:'98'},{label:'Lípidos',val:'31%',g:'31'}].map(m=>
<div class="p-8 hairline-r"><div class="flex justify-between items-center mb-12"><span class="font-label-md text-label-md uppercase tracking-wider">{m.label}</span><span class="font-body-md">{m.g}g</span></div><div class="w-full bg-surface-variant h-1 overflow-hidden"><div class="bg-primary h-full" style="width:{m.val}"></div></div></div>
)}</div>
</section>
<section class="hairline-t py-32 px-margin-mobile md:px-margin-desktop text-center">
<h2 class="font-headline-lg text-[48px] md:text-[64px] mb-12 max-w-4xl mx-auto">{k.bottom_cta}</h2>
<a href={appUrl} class="bg-[#0ea5a0] text-white px-16 py-5 font-label-md text-label-md uppercase tracking-[0.25em] hover:bg-[#0c8f8b] transition-all cursor-pointer inline-block">{k.cta}</a>
</section>
</BaseLayout>
<script>
document.querySelectorAll('button').forEach(function(b){b.addEventListener('mousedown',function(){b.style.transform='scale(0.98)'});b.addEventListener('mouseup',function(){b.style.transform='scale(1)'})});
const o={threshold:0.1};const v=new IntersectionObserver(function(e){e.forEach(function(e){if(e.isIntersecting){e.target.classList.add('opacity-100');e.target.style.transform='translateY(0)'}})},o);
document.querySelectorAll('section').forEach(function(e){e.classList.add('transition-all','duration-700','opacity-0');e.style.transform='translateY(20px)';v.observe(e)});
</script>
