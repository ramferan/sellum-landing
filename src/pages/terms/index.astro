---
import BaseLayout from '../../layouts/BaseLayout.astro';
import t from '../../i18n/en.json';
const lang = 'en';
---
<BaseLayout lang={lang} t={t} title={`${t.terms.title} | SELLUM`} description={t.site.description}>
<article class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-xl" style="max-width:720px">
<h1 class="font-headline-lg text-headline-lg text-primary mb-stack-md">{t.terms.title}</h1>
<p class="text-secondary font-body-md mb-6">{t.terms.updated}</p>
<div class="space-y-6 text-secondary font-body-md leading-relaxed">
<p>By accessing or using our website and services, you agree to be bound by these Terms of Service.</p>
<h2 class="font-headline-lg text-[24px] text-primary mt-8 mb-4">Use License</h2><p>Permission is granted to temporarily access the materials on our website for personal, non-commercial use only.</p>
<h2 class="font-headline-lg text-[24px] text-primary mt-8 mb-4">Disclaimer</h2><p>The materials on our website are provided on an 'as is' basis.</p>
<h2 class="font-headline-lg text-[24px] text-primary mt-8 mb-4">Contact</h2><p><a href="mailto:info@sellumlabs.com" class="text-primary underline">info@sellumlabs.com</a></p>
</div>
</article>
</BaseLayout>
