---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  lang: string;
  t: any;
  title: string;
  description: string;
  variant?: 'sellum' | 'kalosnap' | 'nebula';
  ctaUrl?: string;
}

const { lang, t, title, description, variant = 'sellum' } = Astro.props;
const isSellum = variant === 'sellum';
const isKalosnap = variant === 'kalosnap';
const isNebula = variant === 'nebula';
const fontsLink = isKalosnap
  ? 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap';
const sellumPaths = { en: '/en/', es: '/', pt: '/pt/', fr: '/fr/' };
const kalosnapPaths = { en: '/kalosnap/en/', es: '/kalosnap/', pt: '/kalosnap/pt/', fr: '/kalosnap/fr/' };
const nebulaPaths = { en: '/nebula/en/', es: '/nebula/', pt: '/nebula/pt/', fr: '/nebula/fr/' };
const hreflangPaths = isSellum ? sellumPaths : isKalosnap ? kalosnapPaths : nebulaPaths;
const pagePath = Astro.url.pathname.replace(/\/$/, '');
const isLegalPage = pagePath.startsWith('/privacy') || pagePath.startsWith('/terms');
const baseHreflang = isLegalPage ? pagePath : '';
const sellumConfig = 'tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-dim":"#dadada","surface-bright":"#f9f9f9","background":"#f9f9f9","on-background":"#1a1c1c","surface-variant":"#e2e2e2","primary":"#000000","secondary":"#5d5f5f","on-primary":"#ffffff","on-secondary":"#ffffff","outline":"#7e7576","surface":"#f9f9f9","on-surface":"#1a1c1c"},"borderRadius":{"DEFAULT":"0px","lg":"0px","xl":"0px","full":"9999px"},"spacing":{"margin-desktop":"64px","stack-md":"40px","stack-lg":"80px","gutter":"24px","unit":"8px","stack-xl":"120px","margin-mobile":"24px","container-max":"1280px"},"fontFamily":{"headline-lg":["Playfair Display"],"body-md":["Hanken Grotesk"],"body-lg":["Hanken Grotesk"],"label-caps":["Hanken Grotesk"],"display-lg":["Playfair Display"],"headline-md":["Playfair Display"]},"fontSize":{"headline-lg":["40px",{"lineHeight":"48px","fontWeight":"600"}],"body-lg":["18px",{"lineHeight":"28px","fontWeight":"400"}],"body-md":["16px",{"lineHeight":"24px","fontWeight":"400"}],"label-caps":["12px",{"lineHeight":"16px","letterSpacing":"0.1em","fontWeight":"600"}],"display-lg":["72px",{"lineHeight":"80px","letterSpacing":"-0.02em","fontWeight":"700"}],"headline-md":["24px",{"lineHeight":"32px","fontWeight":"500"}]}}}}';
const kalosnapConfig = 'tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-tint":"#5f5e5e","secondary-fixed-dim":"#c6c7c5","on-secondary-fixed-variant":"#454746","secondary-container":"#e2e3e1","on-tertiary":"#ffffff","on-primary":"#ffffff","inverse-on-surface":"#f2f0f0","surface-dim":"#dbdad9","on-primary-fixed-variant":"#474746","on-tertiary-fixed-variant":"#454747","on-tertiary-container":"#838484","surface-container-low":"#f5f3f3","on-primary-container":"#858383","on-background":"#1b1c1c","secondary":"#5d5f5d","on-tertiary-fixed":"#1a1c1c","tertiary-fixed-dim":"#c6c6c6","tertiary-fixed":"#e2e2e2","surface-container-lowest":"#ffffff","on-surface-variant":"#444748","outline":"#747878","error":"#ba1a1a","on-error-container":"#93000a","on-error":"#ffffff","tertiary":"#000000","primary-fixed-dim":"#c8c6c5","on-secondary-container":"#636563","surface-container-high":"#e9e8e7","primary-fixed":"#e5e2e1","on-secondary-fixed":"#1a1c1b","primary":"#000000","on-secondary":"#ffffff","secondary-fixed":"#e2e3e1","surface-variant":"#e3e2e2","inverse-surface":"#303031","background":"#fbf9f9","surface-bright":"#fbf9f9","surface":"#fbf9f9","error-container":"#ffdad6","tertiary-container":"#1a1c1c","surface-container":"#efeded","on-surface":"#1b1c1c","inverse-primary":"#c8c6c5","outline-variant":"#c4c7c7","primary-container":"#1c1b1b","surface-container-highest":"#e3e2e2","on-primary-fixed":"#1c1b1b"},"borderRadius":{"DEFAULT":"0px","lg":"0px","xl":"0px","full":"9999px"},"spacing":{"unit":"4px","margin-mobile":"16px","margin-desktop":"64px","hairline":"1px","gutter":"24px"},"fontFamily":{"headline-lg":["Playfair Display"],"body-lg":["Inter"],"label-sm":["Inter"],"headline-md":["Playfair Display"],"body-md":["Inter"],"label-md":["Inter"],"display-lg":["Playfair Display"]},"fontSize":{"headline-lg":["40px",{"lineHeight":"1.2","fontWeight":"600"}],"body-lg":["18px",{"lineHeight":"1.6","fontWeight":"400"}],"label-sm":["12px",{"lineHeight":"1","fontWeight":"400"}],"headline-md":["24px",{"lineHeight":"1.3","fontWeight":"500"}],"body-md":["16px",{"lineHeight":"1.5","fontWeight":"400"}],"label-md":["14px",{"lineHeight":"1","fontWeight":"500"}],"display-lg":["72px",{"lineHeight":"0.9","letterSpacing":"-0.03em","fontWeight":"700"}]}}}}';
const nebulaConfig = 'tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-dim":"#dadada","surface-bright":"#f9f9f9","background":"#f9f9f9","on-background":"#1a1c1c","surface-variant":"#e2e2e2","primary":"#000000","secondary":"#5d5f5f","on-primary":"#ffffff","on-secondary":"#ffffff","outline":"#7e7576","surface":"#f9f9f9","on-surface":"#1a1c1c","cyan":"#0891b2","success":"#10b981","danger":"#f43f5e","warning":"#FEB019"},"borderRadius":{"DEFAULT":"0px","lg":"0px","xl":"0px","full":"9999px"},"spacing":{"margin-desktop":"64px","stack-md":"40px","stack-lg":"80px","gutter":"24px","unit":"8px","stack-xl":"120px","margin-mobile":"24px","container-max":"1280px"},"fontFamily":{"headline-lg":["Playfair Display"],"body-md":["Hanken Grotesk"],"body-lg":["Hanken Grotesk"],"label-caps":["Hanken Grotesk"],"display-lg":["Playfair Display"],"headline-md":["Playfair Display"],"mono":["JetBrains Mono","monospace"]},"fontSize":{"headline-lg":["40px",{"lineHeight":"48px","fontWeight":"600"}],"body-lg":["18px",{"lineHeight":"28px","fontWeight":"400"}],"body-md":["16px",{"lineHeight":"24px","fontWeight":"400"}],"label-caps":["12px",{"lineHeight":"16px","letterSpacing":"0.1em","fontWeight":"600"}],"display-lg":["72px",{"lineHeight":"80px","letterSpacing":"-0.02em","fontWeight":"700"}],"headline-md":["24px",{"lineHeight":"32px","fontWeight":"500"}]}}}}';
const tailwindConfig = isSellum ? sellumConfig : isKalosnap ? kalosnapConfig : nebulaConfig;
---

<!DOCTYPE html>
<html class="light" lang={lang}>
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{title}</title>
<meta name="description" content={description}/>
{Object.entries(hreflangPaths).map(([code, path]) => (
  <link rel="alternate" hreflang={code} href={`https://sellumlabs.com${baseHreflang || path}`} />
))}
<link rel="alternate" hreflang="x-default" href="https://sellumlabs.com/"/>
<link href={fontsLink} rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
<script id="tailwind-config" is:inline set:html={tailwindConfig}></script>
<style is:global>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  body { background-color: #f9f9f9; color: #000000; -webkit-font-smoothing: antialiased; }
  .editorial-border { border: 1px solid #E5E5E5; }
  .hover-lift { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
  .hover-lift:hover { transform: translateY(-4px); }
  .hairline-border { border: 1px solid #c4c7c7; }
  .hairline-b { border-bottom: 1px solid #c4c7c7; }
  .hairline-t { border-top: 1px solid #c4c7c7; }
  .hairline-l { border-left: 1px solid #c4c7c7; }
  .hairline-r { border-right: 1px solid #c4c7c7; }
</style>
</head>
<body class="font-body-md text-body-md overflow-x-hidden">
  <Header lang={lang} t={t} variant={variant} ctaUrl={Astro.props.ctaUrl} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} t={t} variant={variant} />
</body>
</html>
