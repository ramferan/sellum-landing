---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  lang: string;
  t: any;
  title: string;
  description: string;
  variant?: 'sellum' | 'kalosnap' | 'nebula';
  ctaUrl?: string;
}

const { lang, t, title, description, variant = 'sellum' } = Astro.props;
const isSellum = variant === 'sellum';
const isKalosnap = variant === 'kalosnap';
const isNebula = variant === 'nebula';
const fontsLink = isKalosnap
  ? 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap';
const sellumPaths = { en: '/en/', es: '/', pt: '/pt/', fr: '/fr/' };
const kalosnapPaths = { en: '/kalosnap/en/', es: '/kalosnap/', pt: '/kalosnap/pt/', fr: '/kalosnap/fr/' };
const nebulaPaths = { en: '/nebula/en/', es: '/nebula/', pt: '/nebula/pt/', fr: '/nebula/fr/' };
const hreflangPaths = isSellum ? sellumPaths : isKalosnap ? kalosnapPaths : nebulaPaths;
const pagePath = Astro.url.pathname.replace(/\/$/, '');
const isLegalPage = pagePath.startsWith('/privacy') || pagePath.startsWith('/terms');
const baseHreflang = isLegalPage ? pagePath : '';
const sellumVars = `--color-surface-dim:#dadada;--color-surface-bright:#f9f9f9;--color-bg:#f9f9f9;--color-on-bg:#1a1c1c;--color-surface-variant:#e2e2e2;--color-primary:#000000;--color-secondary:#5d5f5f;--color-on-primary:#ffffff;--color-on-secondary:#ffffff;--color-outline:#7e7576;--color-surface:#f9f9f9;--color-on-surface:#1a1c1c;--color-accent:#000000;--color-on-accent:#ffffff;--color-accent-hover:#333333`;
const kalosnapVars = `--color-surface-dim:#dbdad9;--color-surface-bright:#fbf9f9;--color-bg:#fbf9f9;--color-on-bg:#1b1c1c;--color-surface-variant:#e3e2e2;--color-primary:#000000;--color-secondary:#5d5f5d;--color-on-primary:#ffffff;--color-on-secondary:#ffffff;--color-outline:#747878;--color-outline-variant:#c4c7c7;--color-surface:#fbf9f9;--color-on-surface:#1b1c1c;--color-surface-container:#efeded;--color-surface-container-low:#f5f3f3;--color-surface-container-lowest:#ffffff;--color-surface-container-high:#e9e8e7;--color-surface-container-highest:#e3e2e2;--color-accent:#0ea5a0;--color-on-accent:#ffffff;--color-accent-hover:#0c8f8b`;
const nebulaVars = `--color-surface-dim:#dadada;--color-surface-bright:#f9f9f9;--color-bg:#f9f9f9;--color-on-bg:#1a1c1c;--color-surface-variant:#e2e2e2;--color-primary:#000000;--color-secondary:#5d5f5f;--color-on-primary:#ffffff;--color-on-secondary:#ffffff;--color-outline:#7e7576;--color-surface:#f9f9f9;--color-on-surface:#1a1c1c;--color-accent:#0891b2;--color-on-accent:#ffffff;--color-accent-hover:#0a7491`;
const variantCssVars = isSellum ? sellumVars : isKalosnap ? kalosnapVars : nebulaVars;
---

<!DOCTYPE html>
<html class="light" lang={lang} style={variantCssVars}>
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{title}</title>
<meta name="description" content={description}/>
{Object.entries(hreflangPaths).map(([code, path]) => (
  <link rel="alternate" hreflang={code} href={`https://sellumlabs.com${baseHreflang || path}`} />
))}
<link rel="alternate" hreflang="x-default" href="https://sellumlabs.com/"/>
<link href={fontsLink} rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style is:global>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  body { background-color: #f9f9f9; color: #000000; -webkit-font-smoothing: antialiased; }
  .editorial-border { border: 1px solid #E5E5E5; }
  .hover-lift { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
  .hover-lift:hover { transform: translateY(-4px); }
  .hairline-border { border: 1px solid #c4c7c7; }
  .hairline-b { border-bottom: 1px solid #c4c7c7; }
  .hairline-t { border-top: 1px solid #c4c7c7; }
  .hairline-l { border-left: 1px solid #c4c7c7; }
  .hairline-r { border-right: 1px solid #c4c7c7; }
</style>
</head>
<body class="font-body-md text-body-md overflow-x-hidden">
  <Header lang={lang} t={t} variant={variant} ctaUrl={Astro.props.ctaUrl} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} t={t} variant={variant} />
</body>
</html>
